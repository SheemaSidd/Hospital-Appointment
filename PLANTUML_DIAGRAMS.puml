@startuml ErrorHandling
!theme plain
title Error Handling Architecture

start
:User action;
decision "Database operation?"
yes
:Try-Except block;
decision "Success?"
yes
:COMMIT transaction;
:Close connection;
:Return result;
stop
no
:Handle exception;
:ROLLBACK (if needed);
:Close connection;
:Return error message;
stop
no
decision "API call?"
yes
:Try-Except block;
decision "Success?"
yes
:Process response;
:Return result;
stop
no
:Catch exception;
:Log error;
:Return error message;
stop
no
decision "Input validation?"
yes
:Check format & type;
decision "Valid?"
yes
:Proceed;
stop
no
:Return validation error;
stop

