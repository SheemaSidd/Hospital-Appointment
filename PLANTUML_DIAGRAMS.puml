@startuml StateTransition
!theme plain
title Appointment State Transitions

[*] --> Available: Slot created

Available --> Booked: book_appointment()
Available --> Available: check_availability()

Booked --> Rescheduled: modify_appointment()
Booked --> Cancelled: cancel_appointment()
Booked --> Completed: Appointment time passed

Rescheduled --> Booked: New date/time set
Rescheduled --> Cancelled: cancel_appointment()

Cancelled --> [*]
Completed --> [*]

note right of Available
  No appointment at this slot
  Can be booked by users
end note

note right of Booked
  Appointment scheduled
  Can be modified or cancelled
end note

@enduml

@startuml ClassDiagram
!theme plain
title Class-like Structure (Functional)

package "Database Module" {
    class Database {
        +init_db()
        +add_sample_appointments()
    }
}

package "Appointment Operations" {
    class AppointmentManager {
        +book_appointment(name, date, time, phone)
        +modify_appointment(id, date, time)
        +cancel_appointment(id)
        +view_appointments()
        +get_appointments_data()
    }
}

package "Validation & Checking" {
    class Validator {
        +check_availability(date, time)
        +get_available_slots(date)
        +parse_natural_date(date_str)
        +parse_natural_time(time_str)
    }
}

package "AI Integration" {
    class ChatManager {
        +hospital_chat(user_message)
        -tools
        -base_messages
        -groq_client
    }
}

Database --> AppointmentManager: uses
Validator --> AppointmentManager: validates
ChatManager --> AppointmentManager: commands
ChatManager --> Validator: processes

@enduml

