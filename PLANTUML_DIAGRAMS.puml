@startuml SystemArchitecture
!theme plain
title Hospital Appointment Booking System - System Architecture

package "Presentation Layer" {
    component Streamlit as ST
    component ChatInterface as CI
    component FormInterface as FI
}

package "Application Logic Layer" {
    component HospitalChat as HC
    component ToolFunctions as TF
    component ParseFunctions as PF
}

package "API Integration Layer" {
    component GroqAPI as GA
    component LLM as LLM_MODEL
}

package "Data Persistence Layer" {
    database SQLiteDB as DB
    entity AppointmentsTable as AT
}

CI --> HC: User message
FI --> TF: Form submission
HC --> GA: Tool definition + Message
GA --> LLM_MODEL: Process request
LLM_MODEL --> GA: Tool decision
HC --> TF: Execute tool
TF --> PF: Parse data
PF --> TF: Formatted data
TF --> DB: Query/Update
DB --> AT: CRUD operations
ST --> CI: Render chat
ST --> FI: Render forms

@enduml

@startuml ChatFlow
!theme plain
title Chat Processing Flow

start
:User enters message;
:Add to chat history;
:Send to Groq API;
:AI processes with tools;
decision "Tool needed?"
yes
:Extract tool name & args;
:Validate arguments;
decision "All required?"
no
:Ask for missing info;
:Return to user;
stop
yes
:Execute tool function;
:Get result;
:Send result to Groq;
:Get final response;
:Add assistant message;
:Display in chat;
stop

@enduml

@startuml BookingSequence
!theme plain
title Appointment Booking Sequence Diagram

participant User
participant ChatUI as "Chat Interface"
participant HospitalChat as "hospital_chat()"
participant ToolFuncs as "Tool Functions"
participant Database as "SQLite DB"
participant GroqAPI as "Groq API"

User -> ChatUI: Type booking request
ChatUI -> HospitalChat: send user message
HospitalChat -> GroqAPI: Create chat completion
GroqAPI -> GroqAPI: Process with LLM
GroqAPI -> HospitalChat: Return tool call
HospitalChat -> ToolFuncs: extract & validate args
ToolFuncs -> ToolFuncs: parse_natural_date()
ToolFuncs -> ToolFuncs: parse_natural_time()
ToolFuncs -> Database: SELECT availability
Database -> ToolFuncs: return count
ToolFuncs -> ToolFuncs: check if available
alt Slot Available
    ToolFuncs -> Database: INSERT appointment
    Database -> ToolFuncs: success
    ToolFuncs -> HospitalChat: confirmation message
else Slot Not Available
    ToolFuncs -> HospitalChat: suggest alternatives
end
HospitalChat -> GroqAPI: Send result back
GroqAPI -> HospitalChat: Final response
HospitalChat -> ChatUI: Display result
ChatUI -> User: Show confirmation/error

@enduml

@startuml DatabaseSchema
!theme plain
title Database Schema - Appointments Table

entity "appointments" {
    * id: INTEGER (PK, AutoIncrement)
    --
    * name: TEXT
    * date: TEXT (YYYY-MM-DD)
    * time: TEXT (HH:MM:SS)
    * phone: TEXT
}

note right of appointments
  Constraints:
  - PK: id (Auto-increment)
  - Unique: (date, time)
  - NOT NULL: All fields
  - Format: ISO 8601 for date/time
end note

@enduml

@startuml AvailabilityCheck
!theme plain
title Availability Checking Algorithm

start
:Input: date, time;
:Connect to database;
:Execute query:
SELECT COUNT(*) FROM appointments
WHERE date = ? AND time = ?;
:Receive count result;
decision "count == 0?"
yes
:Slot is AVAILABLE;
:Return TRUE;
:Close connection;
stop
no
:Slot is NOT AVAILABLE;
:Return FALSE;
:Close connection;
stop

@enduml

@startuml ModifyFlow
!theme plain
title Modify Appointment Flow

start
:User provides: ID, new_date, new_time;
:Validate appointment_id is numeric;
decision "Is numeric?"
no
:Return error;
stop
yes
:Query appointment by ID;
decision "Appointment exists?"
no
:Return "Not found" error;
stop
yes
:Check if new slot available;
decision "New slot available?"
no
:Return "Slot booked" error;
stop
yes
:UPDATE appointment SET date=?, time=?;
:COMMIT transaction;
:Return success message;
stop

@enduml

@startuml CancelFlow
!theme plain
title Cancel Appointment Flow

start
:User provides: appointment_id;
:Convert to integer;
decision "Valid integer?"
no
:Return error;
stop
yes
:Query to find appointment;
decision "Exists?"
no
:Return "Not found" error;
stop
yes
:Store details for confirmation;
:DELETE appointment;
:COMMIT transaction;
:Return cancellation confirmation;
stop

@enduml

@startuml TimeParser
!theme plain
title Natural Time Parsing Algorithm

start
:Input: time_str;
:Normalize: lowercase & trim;
:Replace am/pm variants
with uppercase AM/PM;
:Initialize formats array:
["%I:%M:%S %p", "%I:%M %p",
 "%I %p", "%H:%M:%S", "%H:%M"];
:For each format in formats;
:Try to parse with format;
decision "Parse successful?"
yes
:Convert to HH:MM:SS;
:Return formatted time;
stop
no
:Try next format;
decision "More formats?"
yes
:Continue loop;
no
:Return input as-is;
stop

@enduml

@startuml DateParser
!theme plain
title Natural Date Parsing Algorithm

start
:Input: date_str;
:Normalize: lowercase & trim;
:Get today's date;
decision "date_str == 'today'?"
yes
:Calculate today's date;
:Return YYYY-MM-DD;
stop
no
decision "date_str == 'tomorrow'?"
yes
:Calculate tomorrow's date;
:Return YYYY-MM-DD;
stop
no
decision "date_str == 'next day'?"
yes
:Calculate day after tomorrow;
:Return YYYY-MM-DD;
stop
no
:Try to parse YYYY-MM-DD format;
decision "Parse successful?"
yes
:Return formatted date;
stop
no
:Return input as-is;
stop

@enduml

@startuml SlotGeneration
!theme plain
title Slot Generation Algorithm

start
:Input: date (YYYY-MM-DD);
:Query booked times
SELECT time FROM appointments
WHERE date = ?;
:Convert to set for O(1) lookup;
:Initialize available_slots list;
:For hour = 9 to 16;
  :For minute in [0, 30];
    :Create time_slot (HH:MM:SS);
    decision "In booked_set?"
    no
    :Add to available_slots;
    yes
    :Skip;
    :Next minute;
  :Next hour;
decision "available_slots empty?"
yes
:Return "No available slots";
stop
no
:Format as string with times;
:Return formatted string;
stop

@enduml

